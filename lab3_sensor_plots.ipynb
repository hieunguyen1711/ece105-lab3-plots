  "cells": [
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(1234)\n",
        "# Parameters\n",
        "fs = 100  # Hz\n",
        "duration = 10.0  # seconds\n",
        "t = np.arange(0, duration, 1/fs)\n",
        "n_sensors = 4\n",
        "freqs = [1.0, 0.5, 2.5, 0.2]\n",
        "amps = [1.0, 0.8, 0.6, 1.2]\n",
        "noise_std = 0.25\n",
        "\n",
        "signals = np.zeros((n_sensors, t.size))\n",
        "for i in range(n_sensors):\n",
        "    phase = rng.random() * 2*np.pi\n",
        "    base = amps[i] * np.sin(2*np.pi*freqs[i]*t + phase)\n",
        "    drift = 0.2 * (t/duration) * (i - (n_sensors-1)/2)\n",
        "    noise = noise_std * rng.standard_normal(t.size)\n",
        "    spikes = np.zeros_like(t)\n",
        "    n_spikes = rng.integers(0, 5)\n",
        "    if n_spikes:\n",
        "        idx = rng.choice(t.size, size=n_spikes, replace=False)\n",
        "        spikes[idx] = rng.uniform(2.0, 4.0, size=n_spikes)\n",
        "    signals[i] = base + drift + noise + spikes\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "offset = 4.0\n",
        "for i in range(n_sensors):\n",
        "    plt.plot(t, signals[i] + i*offset, label=f\\"Sensor {i+1}\\")\n",
        "plt.xlabel('Time (s)')\n",
        "plt.ylabel('Signal (offset)')\n",
        "plt.legend(loc='upper right')\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Generate timestamps and two sensor temperature arrays (shape (200,))\n",
        "timestamps = np.linspace(0.0, 10.0, 200, dtype=np.float64)\n",
        "sensor_a = rng.normal(25.0, 3.0, size=200).astype(np.float64)\n",
        "sensor_b = rng.normal(27.0, 4.5, size=200).astype(np.float64)\n",
        "\n",
        "# Quick scatter plot to visualize the synthetic temperature readings\n",
        "plt.figure(figsize=(10,4))\n",
        "plt.plot(timestamps, sensor_a, 'o', label='Sensor A')\n",
        "plt.plot(timestamps, sensor_b, 'o', label='Sensor B')\n",
        "plt.xlabel('Time (s)')\n",
        "plt.ylabel('Temperature (°C)')\n",
        "plt.title('Simulated Temperature Readings (sensor_a, sensor_b shapes: (200,))')\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Scatter plot comparing sensor_a and sensor_b\n",
        "plt.figure(figsize=(6,6))\n",
        "sc = plt.scatter(sensor_a, sensor_b, c=timestamps, cmap='viridis', alpha=0.8)\n",
        "plt.colorbar(sc, label='Time (s)')\n",
        "plt.xlabel('Sensor A (°C)')\n",
        "plt.ylabel('Sensor B (°C)')\n",
        "plt.title('Scatter: Sensor A vs Sensor B (colored by time)')\n",
        "plt.grid(True)\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Histogram of sensor temperatures\n",
        "plt.figure(figsize=(10,4))\n",
        "bins = np.linspace(min(sensor_a.min(), sensor_b.min())-1, max(sensor_a.max(), sensor_b.max())+1, 30)\n",
        "plt.hist(sensor_a, bins=bins, alpha=0.6, label='Sensor A', color='C0')\n",
        "plt.hist(sensor_b, bins=bins, alpha=0.6, label='Sensor B', color='C1')\n",
        "plt.xlabel('Temperature (°C)')\n",
        "plt.ylabel('Count')\n",
        "plt.title('Histogram of Sensor Temperatures')\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Box plot comparing sensor distributions (sensor_a, sensor_b)\n",
        "fig, ax = plt.subplots(figsize=(6,4))\n",
        "bp = ax.boxplot([sensor_a, sensor_b], labels=['Sensor A', 'Sensor B'], patch_artist=True)\n",
        "colors = ['C0', 'C1']\n",
        "for patch, color in zip(bp['boxes'], colors):\n",
        "    patch.set_facecolor(color)\n",
        "    patch.set_alpha(0.6)\n",
        "# Improve whisker/median visibility\n",
        "for median in bp['medians']:\n",
        "    median.set(color='black', linewidth=1.2)\n",
        "ax.set_ylabel('Temperature (°C)')\n",
        "ax.set_title('Box plot of Sensor Temperatures')\n",
        "ax.grid(axis='y', linestyle='--', alpha=0.6)\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    }
  ],
